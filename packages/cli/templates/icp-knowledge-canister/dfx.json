{
  "version": 1,
  "dfx": "0.20.0",
  "canisters": {
    "knolo_knowledge": {
      "type": "custom",
      "candid": "./canisters/knolo-icp-canister/knolo_icp.did",
      "wasm": "./.cargo-target/wasm32-unknown-unknown/release/knolo_icp_canister.wasm",
      "build": [
        "CARGO_TARGET_DIR=./.cargo-target cargo build --target wasm32-unknown-unknown --release --manifest-path ./canisters/knolo-icp-canister/Cargo.toml"
      ],
      "metadata": [
        {
          "name": "candid:service"
        }
      ],
      "declarations": {
        "bindings": [
          "did"
        ],
        "output": "./.dfx/local/declarations/knolo_knowledge"
      }
    }
  }
}
